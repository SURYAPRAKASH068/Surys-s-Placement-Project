# MYSQL_HOST: The hostname of your MySQL server.
# MYSQL_PORT: The port for your MySQL server (default: 3306).
# MYSQL_USER: The username for your MySQL server.
# MYSQL_PASSWORD: The password for your MySQL server.
# MYSQL_DATABASE: The database name for your MySQL server.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# GEMINI_API_KEY: Required for Gemini AI API calls.
# Add your key to the 'Secrets' panel in the AI Studio sidebar.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

JWT_SECRET="super-secret-key-change-this"

# Email Configuration (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Placement Cell <your-email@gmail.com>"
